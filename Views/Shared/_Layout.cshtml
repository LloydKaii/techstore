<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] – TechStore</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
  <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
  <style>
    :root{
      --accent:#00ffff;--accent2:#7b5ea7;--accent3:#ff6b9d;
      --bg:#05080f;--bg2:#0a0f1e;--card:#0f1623;--card2:#141e2e;
      --border:rgba(255,255,255,.06);--border-accent:rgba(0,255,255,.35);
      --text:#e4eaff;--muted:#5a6a85;
      --danger:#ff4d6d;--warning:#fbbf24;--success:#34d399;
      --r:14px;--r-sm:8px;
      --font-head:'Plus Jakarta Sans',sans-serif;
      --font-body:'Space Grotesk',sans-serif;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{font-family:var(--font-body);background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column;overflow-x:hidden;}
    main{flex:1;position:relative;z-index:2;}

    /* ══ PARTICLE CANVAS ══ */
    #ts-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}

    /* ══ AURORA ORBS ══ */
    .aurora{position:fixed;inset:0;z-index:1;pointer-events:none;overflow:hidden;}
    .orb{position:absolute;border-radius:50%;filter:blur(100px);animation:orbDrift ease-in-out infinite;}
    .orb1{width:700px;height:700px;background:radial-gradient(circle,rgba(0,255,255,.06),transparent 65%);top:-200px;left:-200px;animation-duration:18s;}
    .orb2{width:600px;height:600px;background:radial-gradient(circle,rgba(123,94,167,.08),transparent 65%);bottom:-150px;right:-150px;animation-duration:22s;animation-delay:-7s;}
    .orb3{width:400px;height:400px;background:radial-gradient(circle,rgba(255,107,157,.05),transparent 65%);top:40%;left:40%;animation-duration:15s;animation-delay:-4s;}
    .orb4{width:350px;height:350px;background:radial-gradient(circle,rgba(0,200,255,.04),transparent 65%);top:20%;right:20%;animation-duration:20s;animation-delay:-10s;}
    @@keyframes orbDrift{0%,100%{transform:translate(0,0) scale(1);}25%{transform:translate(40px,-30px) scale(1.08);}50%{transform:translate(-20px,40px) scale(.94);}75%{transform:translate(30px,20px) scale(1.04);}}

    /* ══ SCROLLBAR ══ */
    ::-webkit-scrollbar{width:4px;}
    ::-webkit-scrollbar-track{background:var(--bg);}
    ::-webkit-scrollbar-thumb{background:linear-gradient(var(--accent),var(--accent2));border-radius:99px;}

    /* ══ NAVBAR ══ */
    .navbar-main{background:rgba(5,8,15,.82);backdrop-filter:blur(28px) saturate(200%);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:1000;transition:box-shadow .4s;}
    .navbar-main.scrolled{box-shadow:0 2px 40px rgba(0,0,0,.6),0 1px 0 rgba(0,255,255,.06),inset 0 -1px 0 rgba(0,255,255,.04);}
    .navbar-inner{display:flex;align-items:center;justify-content:space-between;height:66px;}
    .brand{font-family:var(--font-head);font-size:1.28rem;font-weight:800;color:var(--text)!important;text-decoration:none;display:flex;align-items:center;gap:11px;letter-spacing:-.3px;}
    .brand-icon{width:38px;height:38px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:.9rem;color:#05080f;flex-shrink:0;box-shadow:0 0 20px rgba(0,255,255,.3),0 0 40px rgba(0,255,255,.1);}
    .brand-text{background:linear-gradient(135deg,#fff 0%,var(--accent) 50%,var(--accent2) 100%);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:shimmerText 4s linear infinite;}
    @@keyframes shimmerText{to{background-position:200% center;}}

    /* Search */
    .search-wrap{position:relative;flex:1;max-width:360px;margin:0 16px;}
    .search-input{width:100%;background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--text);border-radius:50px;padding:9px 42px 9px 18px;font-family:var(--font-body);font-size:.86rem;transition:all .3s;outline:none;}
    .search-input:focus{border-color:var(--accent);background:rgba(0,255,255,.03);box-shadow:0 0 0 3px rgba(0,255,255,.08),0 0 20px rgba(0,255,255,.05);}
    .search-input::placeholder{color:var(--muted);}
    .search-btn{position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer;transition:color .2s;font-size:.85rem;}
    .search-btn:hover{color:var(--accent);}
    .search-drop{position:absolute;top:calc(100% + 10px);left:0;right:0;background:var(--card);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:0 24px 60px rgba(0,0,0,.7),0 0 0 1px rgba(0,255,255,.04);z-index:999;display:none;}
    .search-drop.open{display:block;}
    .s-item{display:flex;align-items:center;gap:12px;padding:11px 15px;cursor:pointer;transition:background .15s;text-decoration:none;color:var(--text);}
    .s-item:hover{background:rgba(0,255,255,.04);}
    .s-img{width:38px;height:38px;object-fit:cover;border-radius:7px;border:1px solid var(--border);flex-shrink:0;}
    .s-noimg{width:38px;height:38px;background:var(--card2);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.7rem;color:var(--muted);flex-shrink:0;}

    /* Nav links */
    .nav-links{display:flex;align-items:center;gap:2px;list-style:none;}
    .nl{color:var(--muted)!important;font-weight:500;font-size:.87rem;padding:7px 13px;border-radius:var(--r-sm);transition:all .25s;text-decoration:none;display:flex;align-items:center;gap:6px;position:relative;}
    .nl::after{content:'';position:absolute;bottom:3px;left:50%;width:0;height:2px;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:1px;transition:all .25s;transform:translateX(-50%);}
    .nl:hover{color:var(--text)!important;background:rgba(255,255,255,.03);}
    .nl:hover::after,.nl.active::after{width:55%;}
    .nl.active{color:var(--accent)!important;}

    /* Right nav */
    .nav-right{display:flex;align-items:center;gap:7px;flex-shrink:0;}
    .btn-cart{position:relative;background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--text)!important;padding:8px 15px;border-radius:var(--r-sm);text-decoration:none;display:flex;align-items:center;gap:7px;font-size:.87rem;font-weight:600;transition:all .25s;}
    .btn-cart:hover{border-color:var(--border-accent);color:var(--accent)!important;box-shadow:0 0 15px rgba(0,255,255,.15);}
    .cbadge{position:absolute;top:-7px;right:-7px;background:linear-gradient(135deg,var(--accent),#00b8d4);color:#05080f;font-size:.6rem;font-weight:800;width:19px;height:19px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:2px solid var(--bg);animation:popIn .3s ease;}
    @@keyframes popIn{from{transform:scale(0);}60%{transform:scale(1.2);}to{transform:scale(1);}}
    .user-btn{background:none;border:1px solid var(--border);color:var(--text);padding:7px 13px;border-radius:var(--r-sm);font-size:.87rem;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:7px;transition:all .2s;font-family:var(--font-body);}
    .user-btn:hover{border-color:var(--border-accent);color:var(--accent);}
    .btn-login{background:linear-gradient(135deg,var(--accent),#00b8d4);color:#05080f!important;font-weight:700;border:none;padding:9px 20px;border-radius:var(--r-sm);font-size:.87rem;text-decoration:none;display:flex;align-items:center;gap:7px;transition:all .25s;box-shadow:0 4px 20px rgba(0,255,255,.25);}
    .btn-login:hover{opacity:.9;transform:translateY(-2px);box-shadow:0 8px 30px rgba(0,255,255,.4);}
    .dd-menu{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:6px;min-width:195px;box-shadow:0 24px 60px rgba(0,0,0,.7),0 0 0 1px rgba(0,255,255,.03);}
    .dd-item{color:var(--muted);font-size:.87rem;padding:9px 14px;border-radius:var(--r-sm);display:flex;align-items:center;gap:9px;text-decoration:none;transition:all .15s;cursor:pointer;background:none;border:none;width:100%;font-family:var(--font-body);}
    .dd-item:hover{background:rgba(0,255,255,.05);color:var(--text);}
    .dd-div{border-top:1px solid var(--border);margin:5px 0;}
    .nav-toggle{display:none;background:none;border:none;color:var(--text);font-size:1.2rem;cursor:pointer;padding:8px;}
    @@media(max-width:768px){.nav-toggle{display:flex;}.nav-links,.search-wrap{display:none;}.nav-links.open{display:flex;flex-direction:column;position:absolute;top:66px;left:0;right:0;background:rgba(5,8,15,.98);padding:12px;border-bottom:1px solid var(--border);z-index:999;}}

    /* ══ ALERTS ══ */
    .alert-ok{display:flex;align-items:center;gap:10px;background:rgba(52,211,153,.07);border:1px solid rgba(52,211,153,.2);color:var(--success);border-radius:var(--r-sm);padding:13px 18px;font-size:.9rem;font-weight:500;}
    .alert-err{background:rgba(255,77,109,.07);border-color:rgba(255,77,109,.2);color:#ff7a8a;}

    /* ══ CARDS ══ */
    .card-dark{background:var(--card);border:1px solid var(--border);border-radius:var(--r);transition:all .3s;}
    .card-dark:hover{border-color:rgba(0,255,255,.18);box-shadow:0 10px 40px rgba(0,0,0,.5),0 0 0 1px rgba(0,255,255,.05);}

    /* ══ TABLE ══ */
    .tbl{color:var(--text);border-collapse:separate;border-spacing:0;width:100%;}
    .tbl thead th{background:var(--card2);border-bottom:1px solid var(--border);color:var(--muted);font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.9px;padding:13px 16px;white-space:nowrap;}
    .tbl tbody td{border-bottom:1px solid var(--border);padding:14px 16px;vertical-align:middle;font-size:.9rem;}
    .tbl tbody tr{transition:background .15s;}
    .tbl tbody tr:hover td{background:rgba(0,255,255,.025);}
    .tbl tbody tr:last-child td{border-bottom:none;}
    /* Alias */
    .table-dark-custom{color:var(--text);border-collapse:separate;border-spacing:0;width:100%;}
    .table-dark-custom thead th{background:var(--card2);border-bottom:1px solid var(--border);color:var(--muted);font-size:.74rem;font-weight:600;text-transform:uppercase;letter-spacing:.9px;padding:13px 16px;white-space:nowrap;}
    .table-dark-custom tbody td{border-bottom:1px solid var(--border);padding:14px 16px;vertical-align:middle;font-size:.9rem;}
    .table-dark-custom tbody tr:hover td{background:rgba(0,255,255,.025);}
    .table-dark-custom tbody tr:last-child td{border-bottom:none;}

    /* ══ FORM ══ */
    .form-label-custom{color:var(--text);font-size:.83rem;font-weight:600;margin-bottom:7px;display:block;}
    .form-control-dark{background:var(--bg2)!important;border:1.5px solid var(--border)!important;color:var(--text)!important;border-radius:var(--r-sm)!important;padding:11px 14px!important;font-family:var(--font-body);font-size:.9rem;transition:all .25s;}
    .form-control-dark:focus{border-color:var(--accent)!important;box-shadow:0 0 0 3px rgba(0,255,255,.1),0 0 20px rgba(0,255,255,.05)!important;outline:none!important;}
    .form-control-dark::placeholder{color:var(--muted);}
    .form-control-dark option{background:var(--card2);}

    /* ══ BUTTONS ══ */
    .btn-primary-custom{background:linear-gradient(135deg,var(--accent),#00b8d4);color:#05080f!important;border:none;padding:11px 26px;border-radius:var(--r-sm);font-weight:700;font-size:.9rem;cursor:pointer;transition:all .25s;text-decoration:none;display:inline-flex;align-items:center;gap:7px;box-shadow:0 4px 18px rgba(0,255,255,.22);}
    .btn-primary-custom:hover{opacity:.92;transform:translateY(-2px);box-shadow:0 8px 32px rgba(0,255,255,.38);}
    .btn-secondary-custom{background:rgba(255,255,255,.04);color:var(--muted)!important;border:1.5px solid var(--border);padding:11px 26px;border-radius:var(--r-sm);font-weight:600;font-size:.9rem;cursor:pointer;transition:all .25s;text-decoration:none;display:inline-flex;align-items:center;gap:7px;}
    .btn-secondary-custom:hover{border-color:var(--border-accent);color:var(--accent)!important;background:rgba(0,255,255,.03);}
    .btn-danger-custom{background:rgba(255,77,109,.07);color:#ff7a8a!important;border:1px solid rgba(255,77,109,.18);padding:7px 14px;border-radius:var(--r-sm);font-size:.82rem;font-weight:600;text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:5px;}
    .btn-danger-custom:hover{background:var(--danger);color:#fff!important;border-color:var(--danger);box-shadow:0 4px 16px rgba(255,77,109,.3);}
    .btn-edit-custom{background:rgba(0,255,255,.06);color:var(--accent)!important;border:1px solid rgba(0,255,255,.14);padding:7px 14px;border-radius:var(--r-sm);font-size:.82rem;font-weight:600;text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:5px;}
    .btn-edit-custom:hover{background:var(--accent);color:#05080f!important;box-shadow:0 0 15px rgba(0,255,255,.3);}
    .btn-view-custom{background:rgba(251,191,36,.06);color:var(--warning)!important;border:1px solid rgba(251,191,36,.16);padding:7px 14px;border-radius:var(--r-sm);font-size:.82rem;font-weight:600;text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:5px;}
    .btn-view-custom:hover{background:var(--warning);color:#05080f!important;}

    /* ══ MISC ══ */
    .badge-cat{background:rgba(123,94,167,.14);color:#c4aff0;border:1px solid rgba(123,94,167,.22);padding:3px 10px;border-radius:99px;font-size:.72rem;font-weight:600;}
    .product-img-preview{width:44px;height:44px;object-fit:cover;border-radius:var(--r-sm);border:1px solid var(--border);}
    .text-accent{color:var(--accent)!important;}
    .text-danger{color:#ff7a8a!important;font-size:.82rem;}
    .field-validation-error{color:#ff7a8a;font-size:.82rem;}
    .input-validation-error{border-color:var(--danger)!important;}
    .section-title{font-family:var(--font-head);font-size:1.35rem;font-weight:800;letter-spacing:-.3px;display:flex;align-items:center;gap:10px;}
    .section-title::before{content:'';display:block;width:4px;height:22px;background:linear-gradient(to bottom,var(--accent),var(--accent2));border-radius:2px;flex-shrink:0;box-shadow:0 0 10px rgba(0,255,255,.5);}
    .page-header{background:linear-gradient(160deg,rgba(10,15,30,.95) 0%,rgba(15,22,35,.95) 100%);border-bottom:1px solid var(--border);padding:36px 0;position:relative;overflow:hidden;z-index:2;}
    .page-header::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 100% at 85% 50%,rgba(0,255,255,.04) 0%,transparent 60%);}
    .page-header h1{font-family:var(--font-head);font-size:1.65rem;font-weight:800;letter-spacing:-.4px;}

    /* ══ ANIMATIONS ══ */
    @@keyframes fadeUp{from{opacity:0;transform:translateY(22px);}to{opacity:1;transform:translateY(0);}}
    @@keyframes glowPulse{0%,100%{box-shadow:0 0 5px rgba(0,255,255,.15);}50%{box-shadow:0 0 25px rgba(0,255,255,.45),0 0 50px rgba(0,255,255,.08);}}
    @@keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-8px);}}
    .animate-in{animation:fadeUp .5s ease both;}
    .animate-in-delay{animation:fadeUp .5s ease .12s both;}
    .animate-in-delay2{animation:fadeUp .5s ease .24s both;}
    .animate-in-delay3{animation:fadeUp .5s ease .36s both;}
    .glow-anim{animation:glowPulse 2.5s ease-in-out infinite;}
    .float-anim{animation:float 4s ease-in-out infinite;}

    /* ══ CHATBOT ══ */
    .chat-fab{position:fixed;bottom:28px;right:28px;z-index:900;width:58px;height:58px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:50%;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.35rem;color:#05080f;box-shadow:0 4px 24px rgba(0,255,255,.4),0 0 0 0 rgba(0,255,255,.3);transition:all .3s;animation:glowPulse 3s ease-in-out infinite;}
    .chat-fab:hover{transform:scale(1.12) rotate(5deg);}
    .chat-dot{position:absolute;top:3px;right:3px;width:13px;height:13px;background:var(--success);border-radius:50%;border:2px solid var(--bg);animation:glowPulse 1.5s infinite;}
    .chat-win{position:fixed;bottom:98px;right:28px;z-index:900;width:345px;background:var(--card);border:1px solid var(--border);border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.7),0 0 0 1px rgba(0,255,255,.04);overflow:hidden;display:none;flex-direction:column;max-height:520px;}
    .chat-win.open{display:flex;animation:fadeUp .3s ease;}
    .chat-hdr{background:linear-gradient(135deg,rgba(0,255,255,.08),rgba(123,94,167,.08));padding:15px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:11px;}
    .chat-av{width:38px;height:38px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.95rem;color:#05080f;flex-shrink:0;}
    .chat-msgs{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px;min-height:220px;}
    .cmsg{max-width:86%;padding:10px 14px;border-radius:14px;font-size:.85rem;line-height:1.55;}
    .cmsg.bot{background:var(--card2);border:1px solid var(--border);border-radius:14px 14px 14px 4px;align-self:flex-start;}
    .cmsg.user{background:linear-gradient(135deg,rgba(0,255,255,.12),rgba(123,94,167,.12));border:1px solid rgba(0,255,255,.12);border-radius:14px 14px 4px 14px;align-self:flex-end;}
    .chat-typing{display:none;gap:5px;align-items:center;padding:10px 14px;background:var(--card2);border-radius:14px;width:fit-content;}
    .chat-typing span{width:6px;height:6px;background:var(--muted);border-radius:50%;animation:typeBounce .9s ease-in-out infinite;}
    .chat-typing span:nth-child(2){animation-delay:.15s;}
    .chat-typing span:nth-child(3){animation-delay:.3s;}
    @@keyframes typeBounce{0%,60%,100%{transform:translateY(0);}30%{transform:translateY(-7px);}}
    .chat-inp-wrap{padding:12px;border-top:1px solid var(--border);display:flex;gap:8px;}
    .chat-inp{flex:1;background:var(--bg2);border:1px solid var(--border);color:var(--text);border-radius:50px;padding:9px 16px;font-family:var(--font-body);font-size:.85rem;outline:none;transition:border-color .2s;}
    .chat-inp:focus{border-color:var(--accent);}
    .chat-send{width:36px;height:36px;background:linear-gradient(135deg,var(--accent),var(--accent2));border:none;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#05080f;font-size:.85rem;transition:all .2s;flex-shrink:0;}
    .chat-send:hover{transform:scale(1.1);}

    /* ══ FOOTER ══ */
    footer{background:#030507;border-top:1px solid var(--border);padding:36px 0;position:relative;z-index:2;}
    .foot-inner{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;}
    .foot-links{display:flex;gap:20px;}
    .foot-links a{color:var(--muted);text-decoration:none;font-size:.85rem;transition:color .2s;}
    .foot-links a:hover{color:var(--accent);}
  </style>
  @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- AURORA -->
<div class="aurora">
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>
  <div class="orb orb3"></div>
  <div class="orb orb4"></div>
</div>

<!-- PARTICLE CANVAS -->
<canvas id="ts-canvas"></canvas>

<!-- NAVBAR -->
<nav class="navbar-main" id="navbar">
  <div class="container">
    <div class="navbar-inner">
      <a class="brand" href="/">
        <div class="brand-icon float-anim"><i class="fa-solid fa-microchip"></i></div>
        <span class="brand-text">TechStore</span>
      </a>
      <button class="nav-toggle" onclick="document.getElementById('nl').classList.toggle('open')">
        <i class="fa-solid fa-bars"></i>
      </button>

      <!-- Smart Search -->
      <div class="search-wrap d-none d-md-block">
        <input id="sInput" class="search-input" type="text" placeholder="🔍 Tìm sản phẩm... (gõ nhầm vẫn tìm được)"/>
        <button class="search-btn" onclick="doSearch()"><i class="fa-solid fa-magnifying-glass"></i></button>
        <div class="search-drop" id="sDrop"><div id="sRes"></div></div>
      </div>

      <ul class="nav-links" id="nl">
        <li><a class="nl @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")" href="/"><i class="fa-solid fa-house"></i>Trang chủ</a></li>
        <li><a class="nl @(ViewContext.RouteData.Values["controller"]?.ToString()=="Product"?"active":"")" href="/Product"><i class="fa-solid fa-laptop"></i>Sản phẩm</a></li>
        <li><a class="nl @(ViewContext.RouteData.Values["controller"]?.ToString()=="Build"?"active":"")" href="/Build"><i class="fa-solid fa-screwdriver-wrench"></i>Build PC</a></li>
        <li><a class="nl @(ViewContext.RouteData.Values["controller"]?.ToString()=="Category"?"active":"")" href="/Category"><i class="fa-solid fa-tags"></i>Danh mục</a></li>
        @if(User.IsInRole("Admin")||User.IsInRole("Manager")){
          <li><a class="nl @(ViewContext.RouteData.Values["controller"]?.ToString()=="Admin"?"active":"")" href="/Admin/Dashboard"><i class="fa-solid fa-gauge"></i>Admin</a></li>
        }
      </ul>


      <div class="nav-right">
        @{ var cs=Context.RequestServices.GetService<TechStore.Services.CartService>(); var cc=cs?.Count??0; }
        <a href="/Cart" class="btn-cart">
          <i class="fa-solid fa-bag-shopping"></i>
          <span class="d-none d-lg-inline">Giỏ</span>
          @if(cc>0){<span class="cbadge">@(cc>9?"9+":cc.ToString())</span>}
        </a>
        @if(User.Identity?.IsAuthenticated==true){
          <div class="dropdown">
            <button class="user-btn dropdown-toggle" data-bs-toggle="dropdown">
              <i class="fa-solid fa-circle-user"></i>
              <span class="d-none d-lg-inline">@User.Identity.Name?.Split('@')[0]</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end dd-menu">
              <li><a class="dd-item" href="/Account/Profile"><i class="fa-solid fa-user text-accent"></i>Hồ sơ</a></li>
              <li><a class="dd-item" href="/Order/MyOrders"><i class="fa-solid fa-bag-shopping" style="color:var(--success);"></i>Đơn hàng của tôi</a></li>
              <li><a class="dd-item" href="/Wishlist"><i class="fa-solid fa-heart" style="color:#ff7a8a;"></i>Yêu thích</a></li>
              @if(User.IsInRole("Admin")||User.IsInRole("Manager")){
                <li><div class="dd-div"></div></li>
                <li><a class="dd-item" href="/Admin/Dashboard"><i class="fa-solid fa-gauge text-accent"></i>Dashboard</a></li>
                <li><a class="dd-item" href="/Order/Manage"><i class="fa-solid fa-list-check" style="color:var(--warning);"></i>Quản lý đơn hàng</a></li>
              }
              <li><div class="dd-div"></div></li>
              <li>
                <form asp-controller="Account" asp-action="Logout" method="post">
                  <button type="submit" class="dd-item" style="color:#ff7a8a;">
                    <i class="fa-solid fa-right-from-bracket"></i>Đăng xuất
                  </button>
                </form>
              </li>
            </ul>
          </div>
        } else {
          <a href="/Account/Login" class="btn-login">
            <i class="fa-solid fa-right-to-bracket"></i>
            <span class="d-none d-sm-inline">Đăng nhập</span>
          </a>
        }
      </div>
    </div>
  </div>
</nav>

<!-- MAIN -->
<main>
  @if(TempData["Success"]!=null){
    <div class="container mt-4 animate-in">
      <div class="alert-ok"><i class="fa-solid fa-circle-check"></i> @TempData["Success"]</div>
    </div>
  }
  @if(TempData["Error"]!=null){
    <div class="container mt-4 animate-in">
      <div class="alert-ok alert-err"><i class="fa-solid fa-triangle-exclamation"></i> @TempData["Error"]</div>
    </div>
  }
  @RenderBody()
</main>

<!-- FOOTER -->
<footer>
  <div class="container">
    <div class="foot-inner">
      <div class="brand" style="font-size:.95rem;">
        <div class="brand-icon" style="width:28px;height:28px;font-size:.75rem;"><i class="fa-solid fa-microchip"></i></div>
        <span class="brand-text">TechStore</span>
      </div>
      <div class="foot-links">
        <a href="/">Trang chủ</a><a href="/Product">Sản phẩm</a>
        <a href="/Category">Danh mục</a><a href="/Cart">Giỏ hàng</a>
      </div>
      <p style="color:var(--muted);font-size:.8rem;">© 2025 TechStore · ASP.NET Core + AI</p>
    </div>
  </div>
</footer>

<!-- CHATBOT FAB -->
<button class="chat-fab" onclick="toggleChat()" title="TechBot AI">
  <i class="fa-solid fa-robot" id="chatIcon"></i>
  <span class="chat-dot"></span>
</button>

<!-- CHAT WINDOW -->
<div class="chat-win" id="chatWin">
  <div class="chat-hdr">
    <div class="chat-av"><i class="fa-solid fa-robot"></i></div>
    <div style="flex:1;">
      <div style="font-weight:700;font-size:.9rem;font-family:var(--font-head);">TechBot AI</div>
      <div style="font-size:.75rem;color:var(--muted);">Trợ lý mua sắm thông minh</div>
    </div>
    <div style="width:8px;height:8px;background:var(--success);border-radius:50%;animation:glowPulse 1.5s infinite;"></div>
    <button onclick="toggleChat()" style="background:none;border:none;color:var(--muted);cursor:pointer;padding:4px;margin-left:8px;"><i class="fa-solid fa-xmark"></i></button>
  </div>
  <div class="chat-msgs" id="chatMsgs">
    <div class="cmsg bot">👋 Xin chào! Tôi là <strong>TechBot</strong> — AI của TechStore.<br/>Hỏi tôi về sản phẩm, giá, bảo hành hay tư vấn cấu hình nhé!</div>
    <div class="cmsg bot">💡 <em>Thử: "laptop gaming", "sản phẩm rẻ nhất", "bảo hành bao lâu"</em></div>
  </div>
  <div class="chat-typing" id="chatTyping"><span></span><span></span><span></span></div>
  <div class="chat-inp-wrap">
    <input class="chat-inp" id="chatInp" placeholder="Nhập câu hỏi..." onkeydown="if(event.key==='Enter')sendChat()"/>
    <button class="chat-send" onclick="sendChat()"><i class="fa-solid fa-paper-plane"></i></button>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ══ PARTICLES ═══════════════════════════════════════════
const C=document.getElementById('ts-canvas'),X=C.getContext('2d');
let W,H,pts=[];
function resize(){W=C.width=innerWidth;H=C.height=innerHeight;}
resize();addEventListener('resize',resize);
class Pt{
  constructor(){this.reset(true);}
  reset(init){
    this.x=Math.random()*W; this.y=init?Math.random()*H:Math.random()*H;
    this.vx=(Math.random()-.5)*.5; this.vy=(Math.random()-.5)*.5;
    this.r=Math.random()*1.8+.4;
    this.a=Math.random()*.5+.1;
    const p=Math.random();
    this.c=p<.4?'0,255,255':p<.7?'123,94,167':'255,107,157';
    this.pulse=Math.random()*Math.PI*2;
    this.pulseSpeed=Math.random()*.02+.01;
  }
  tick(){
    this.x+=this.vx; this.y+=this.vy;
    this.pulse+=this.pulseSpeed;
    if(this.x<0||this.x>W||this.y<0||this.y>H)this.reset(false);
  }
  draw(){
    const pa=this.a*(0.7+0.3*Math.sin(this.pulse));
    X.beginPath();X.arc(this.x,this.y,this.r,0,Math.PI*2);
    X.fillStyle=`rgba(${this.c},${pa})`;X.fill();
  }
}
for(let i=0;i<100;i++)pts.push(new Pt());

// Mouse interaction
let mx=W/2,my=H/2;
addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;});

function drawLines(){
  for(let i=0;i<pts.length;i++){
    for(let j=i+1;j<pts.length;j++){
      const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.hypot(dx,dy);
      if(d<130){
        X.beginPath();X.moveTo(pts[i].x,pts[i].y);X.lineTo(pts[j].x,pts[j].y);
        X.strokeStyle=`rgba(0,255,255,${.08*(1-d/130)})`;X.lineWidth=.6;X.stroke();
      }
    }
    // Mouse repel glow
    const mdx=pts[i].x-mx,mdy=pts[i].y-my,md=Math.hypot(mdx,mdy);
    if(md<100){
      X.beginPath();X.moveTo(pts[i].x,pts[i].y);X.lineTo(mx,my);
      X.strokeStyle=`rgba(0,255,255,${.15*(1-md/100)})`;X.lineWidth=.8;X.stroke();
    }
  }
}

function loop(){
  X.clearRect(0,0,W,H);
  pts.forEach(p=>{p.tick();p.draw();});
  drawLines();
  requestAnimationFrame(loop);
}
loop();

// ══ NAVBAR SCROLL ════════════════════════════════════════
addEventListener('scroll',()=>document.getElementById('navbar').classList.toggle('scrolled',scrollY>30));

// ══ SCROLL REVEAL ════════════════════════════════════════
const obs=new IntersectionObserver(ents=>{
  ents.forEach(e=>{if(e.isIntersecting){e.target.classList.add('_vis');}});
},{threshold:.08});
document.querySelectorAll('.card-dark,[data-reveal]').forEach(el=>{
  el.style.cssText='opacity:0;transform:translateY(24px);transition:opacity .55s ease,transform .55s ease;';
  obs.observe(el);
});
document.addEventListener('animationend',()=>{});
const visObs=new MutationObserver(()=>{});
document.querySelectorAll('._vis').forEach(el=>{el.style.opacity='1';el.style.transform='translateY(0)';});
setInterval(()=>{
  document.querySelectorAll('._vis').forEach(el=>{el.style.opacity='1';el.style.transform='translateY(0)';});
},100);

// ══ SMART SEARCH ════════════════════════════════════════
let sTimer;
const sInp=document.getElementById('sInput'),sDrop=document.getElementById('sDrop'),sRes=document.getElementById('sRes');
if(sInp){
  sInp.addEventListener('input',function(){
    clearTimeout(sTimer);
    const q=this.value.trim();
    if(q.length<2){sDrop.classList.remove('open');return;}
    sTimer=setTimeout(()=>doSearch(q),280);
  });
  document.addEventListener('click',e=>{if(!sInp.contains(e.target)&&!sDrop.contains(e.target))sDrop.classList.remove('open');});
}
async function doSearch(q){
  if(!q&&sInp)q=sInp.value.trim();
  if(!q)return;
  try{
    const r=await fetch(`/AI/Search?q=${encodeURIComponent(q)}`),d=await r.json();
    sRes.innerHTML=d.results.length
      ?d.results.map(r=>`<a href="${r.url}" class="s-item">${r.image?`<img src="${r.image}" class="s-img" alt="${r.name}"/>`:`<div class="s-noimg"><i class="fa-solid fa-image"></i></div>`}<div style="flex:1;min-width:0;"><div style="font-size:.87rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${r.name}</div><div style="font-size:.78rem;color:var(--accent);font-weight:700;">${r.price}</div></div></a>`).join('')
      :'<div style="padding:16px;color:var(--muted);font-size:.85rem;text-align:center;">Không tìm thấy kết quả</div>';
    sDrop.classList.add('open');
  }catch(e){console.error(e);}
}

// ══ CHATBOT ══════════════════════════════════════════════
function toggleChat(){
  const w=document.getElementById('chatWin'),i=document.getElementById('chatIcon');
  const o=w.classList.toggle('open');
  i.className=o?'fa-solid fa-xmark':'fa-solid fa-robot';
  if(o)document.getElementById('chatInp').focus();
}
async function sendChat(){
  const inp=document.getElementById('chatInp'),msg=inp.value.trim();
  if(!msg)return;
  addMsg(msg,'user');inp.value='';
  const ty=document.getElementById('chatTyping');
  ty.style.display='flex';scrollChat();
  try{
    const r=await fetch('/AI/Chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:msg})});
    const d=await r.json();
    ty.style.display='none';addMsg(d.reply,'bot');
  }catch(e){ty.style.display='none';addMsg('Xin lỗi, có lỗi xảy ra!','bot');}
}
function addMsg(t,type){
  const m=document.getElementById('chatMsgs'),d=document.createElement('div');
  d.className=`cmsg ${type}`;
  d.innerHTML=t.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n/g,'<br/>');
  m.appendChild(d);scrollChat();
}
function scrollChat(){const m=document.getElementById('chatMsgs');m.scrollTop=m.scrollHeight;}
</script>
<script src="/js/effects.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
