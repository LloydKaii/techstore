@model TechStore.Models.ApplicationUser

@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
}

<style>
    .profile-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .profile-header {
        background: linear-gradient(135deg, rgba(0,255,255,.08) 0%, rgba(123,94,167,.08) 100%);
        border: 1px solid rgba(0,255,255,.1);
        border-radius: var(--r);
        padding: 40px 30px;
        text-align: center;
        margin-bottom: 32px;
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        background: linear-gradient(135deg, var(--accent), var(--accent2));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 3rem;
        color: #05080f;
        box-shadow: 0 0 30px rgba(0,255,255,.3);
    }

    .profile-name {
        font-family: var(--font-head);
        font-size: 1.8rem;
        font-weight: 800;
        margin: 0 0 8px 0;
        color: var(--text);
    }

    .profile-email {
        color: var(--muted);
        font-size: 0.95rem;
    }

    .tabs-container {
        display: flex;
        gap: 8px;
        border-bottom: 2px solid var(--border);
        margin-bottom: 32px;
        flex-wrap: wrap;
    }

    .tab-link {
        color: var(--muted) !important;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 14px 20px;
        border: none;
        background: none;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.3s;
        border-bottom: 3px solid transparent;
        position: relative;
        top: 2px;
    }

    .tab-link:hover {
        color: var(--text) !important;
        background: rgba(0,255,255,.03);
    }

    .tab-link.active {
        color: var(--accent) !important;
        border-bottom-color: var(--accent);
        background: rgba(0,255,255,.05);
    }

    .tab-content {
        display: none;
        animation: fadeUp 0.3s ease;
    }

    .tab-content.active {
        display: block;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-group label {
        display: block;
        color: var(--text);
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-group input {
        width: 100%;
        background: var(--bg2) !important;
        border: 1.5px solid var(--border) !important;
        color: var(--text) !important;
        padding: 12px 16px !important;
        border-radius: var(--r-sm) !important;
        font-family: var(--font-body);
        font-size: 0.9rem;
        transition: all 0.25s;
    }

    .form-group input:focus {
        border-color: var(--accent) !important;
        box-shadow: 0 0 0 3px rgba(0,255,255,.1), 0 0 20px rgba(0,255,255,.05) !important;
        outline: none !important;
    }

    .form-group input:disabled {
        background: rgba(255,255,255,.02) !important;
        cursor: not-allowed;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
    }

    .btn-update {
        background: linear-gradient(135deg, var(--accent), #00b8d4);
        color: #05080f !important;
        border: none;
        padding: 13px 32px;
        border-radius: var(--r-sm);
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.25s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 18px rgba(0,255,255,.22);
    }

    .btn-update:hover {
        opacity: 0.92;
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(0,255,255,.38);
    }

    .card-info {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--r);
        padding: 24px;
        margin-bottom: 24px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 0;
        border-bottom: 1px solid var(--border);
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 600;
    }

    .info-value {
        color: var(--text);
        font-size: 0.9rem;
    }
</style>

<!-- PAGE HEADER -->
<div class="page-header">
    <div class="container">
        <h1>👤 Hồ Sơ Cá Nhân</h1>
        <p class="text-muted">Quản lý thông tin tài khoản của bạn</p>
    </div>
</div>

<div class="container profile-container py-5">
    
    <!-- USER INFO CARD -->
    <div class="profile-header">
        <div class="profile-avatar">
            <i class="fa-solid fa-circle-user"></i>
        </div>
        <h2 class="profile-name">@Model.FullName</h2>
        <p class="profile-email">@Model.Email</p>
    </div>

    <!-- TABS -->
    <div class="tabs-container">
        <button type="button" onclick="switchTab('info')" class="tab-link active">ℹ️ Thông Tin Cá Nhân</button>
        <button type="button" onclick="switchTab('address')" class="tab-link">📍 Địa Chỉ</button>
        <button type="button" onclick="switchTab('password')" class="tab-link">🔐 Đổi Mật Khẩu</button>
    </div>

    <!-- TAB 1: THÔNG TIN CÁ NHÂN -->
    <div id="tab-info" class="tab-content active">
        <div class="card-dark p-5" style="border-radius: var(--r);">
            <h3 style="margin-bottom: 24px; color: var(--accent); font-family: var(--font-head);">Cập Nhật Thông Tin</h3>
            
            <form asp-action="UpdateProfile" method="post">
                <div class="form-row">
                    <div class="form-group">
                        <label>Tên Đầy Đủ</label>
                        <input type="text" name="fullName" asp-for="FullName" placeholder="Nhập tên đầy đủ của bạn" />
                    </div>
                    
                    <div class="form-group">
                        <label>Email (Không thể thay đổi)</label>
                        <input type="email" asp-for="Email" disabled />
                    </div>
                </div>
                
                <div class="form-group">
                    <label>Số Điện Thoại</label>
                    <input type="tel" name="phone" placeholder="0xxxxxxxxx" value="@(Model.PhoneNumber ?? "")" />
                </div>
                
                <button type="submit" class="btn-update">
                    <i class="fa-solid fa-check"></i> Cập Nhật Thông Tin
                </button>
            </form>
        </div>
    </div>

    <!-- TAB 2: ĐỊA CHỈ -->
    <div id="tab-address" class="tab-content">
        <div class="card-dark p-5" style="border-radius: var(--r);">
            <h3 style="margin-bottom: 24px; color: var(--accent); font-family: var(--font-head);">Địa Chỉ Của Bạn</h3>
            
            <form>
                <div class="form-group">
                    <label>Địa Chỉ Chi Tiết</label>
                    <input type="text" placeholder="Số nhà, đường phố" value="@(Model.Address ?? "")" />
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label>Thành Phố / Tỉnh</label>
                        <input type="text" placeholder="Hồ Chí Minh, Hà Nội, ..." />
                    </div>
                    <div class="form-group">
                        <label>Quốc Gia</label>
                        <input type="text" placeholder="Việt Nam" value="Việt Nam" />
                    </div>
                </div>
                
                <button type="submit" class="btn-update">
                    <i class="fa-solid fa-check"></i> Cập Nhật Địa Chỉ
                </button>
            </form>
        </div>
    </div>

    <!-- TAB 3: ĐỔI MẬT KHẨU -->
    <div id="tab-password" class="tab-content">
        <div class="card-dark p-5" style="border-radius: var(--r);">
            <h3 style="margin-bottom: 24px; color: var(--accent); font-family: var(--font-head);">Đổi Mật Khẩu</h3>
            
            <form asp-action="ChangePassword" method="post">
                <div class="form-group">
                    <label>Mật Khẩu Hiện Tại</label>
                    <input type="password" name="currentPassword" placeholder="Nhập mật khẩu hiện tại" required />
                </div>
                
                <div class="form-group">
                    <label>Mật Khẩu Mới</label>
                    <input type="password" name="newPassword" placeholder="Nhập mật khẩu mới" required />
                </div>
                
                <div class="form-group">
                    <label>Xác Nhận Mật Khẩu</label>
                    <input type="password" name="confirmPassword" placeholder="Xác nhận mật khẩu mới" required />
                </div>
                
                <button type="submit" class="btn-update">
                    <i class="fa-solid fa-lock"></i> Cập Nhật Mật Khẩu
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    function switchTab(tab) {
        // Hide all tabs
        document.querySelectorAll('.tab-content').forEach(el => {
            el.classList.remove('active');
        });
        
        // Deactivate all buttons
        document.querySelectorAll('.tab-link').forEach(el => {
            el.classList.remove('active');
        });
        
        // Show selected tab and activate button
        document.getElementById('tab-' + tab).classList.add('active');
        event.target.classList.add('active');
    }
</script>
        
        <!-- Divider -->
        <hr style="margin: 32px 0; border-color: var(--border);">
        
        <!-- Quick Actions -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
            <a href="/Order" class="btn-secondary-custom" style="display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none;">
                <i class="fa-solid fa-bag-shopping"></i>
                Đơn Hàng Của Tôi
            </a>
            <a href="/Wishlist" class="btn-secondary-custom" style="display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none;">
                <i class="fa-solid fa-heart" style="color: #ff6b9d;"></i>
                Wishlist
            </a>
        </div>
        
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <div style="margin-top: 12px;">
                <a href="/Admin/Dashboard" class="btn-primary-custom w-100" style="display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none;">
                    <i class="fa-solid fa-gauge"></i>
                    Admin Dashboard
                </a>
            </div>
        }
        
        <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top: 12px;">
            <button type="submit" class="btn-danger-custom w-100" style="border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;">
                <i class="fa-solid fa-right-from-bracket"></i>
                Đăng Xuất
            </button>
        </form>
    </div>
</div>

<style>
.tab-link {
    padding: 12px 16px;
    color: var(--muted);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: all .2s;
    cursor: pointer;
    font-weight: 600;
}

.tab-link:hover,
.tab-link.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
}

.tab-content {
    animation: fadeIn 0.3s ease;
}

@@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}
</style>

<script>
function switchTab(tabName) {
    document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
    document.querySelectorAll('.tab-link').forEach(el => el.classList.remove('active'));
    
    document.getElementById('tab-' + tabName).style.display = 'block';
    event.target.classList.add('active');
}
</script>
