@{ ViewData["Title"] = "Đặt hàng thành công"; }

<style>
@@keyframes checkPop{0%{transform:scale(0);opacity:0;}60%{transform:scale(1.25);}100%{transform:scale(1);opacity:1;}}
.check-circle{animation:checkPop .55s cubic-bezier(.175,.885,.32,1.275) both .15s;}
</style>

<div style="min-height:calc(100vh - 130px);display:flex;align-items:center;justify-content:center;padding:40px 16px;">
  <div style="text-align:center;max-width:540px;width:100%;" class="animate-in">

    <div style="margin-bottom:24px;">
      <div class="check-circle" style="width:90px;height:90px;background:linear-gradient(135deg,var(--success),#059669);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto;font-size:2.4rem;color:white;box-shadow:0 0 50px rgba(52,211,153,.25);">
        <i class="fa-solid fa-check"></i>
      </div>
    </div>

    <h2 style="font-family:var(--font-head);font-size:1.9rem;font-weight:800;margin-bottom:8px;">Đặt hàng thành công! 🎉</h2>
    <p style="color:var(--muted);line-height:1.7;margin-bottom:28px;">
      Cảm ơn bạn đã tin tưởng mua sắm tại <strong style="color:var(--accent);">TechStore</strong>.<br/>
      Đội ngũ chúng tôi sẽ xác nhận đơn hàng trong vòng 2-4 giờ.
    </p>

    @if(TempData["OrderName"] != null){
      <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:20px;text-align:left;margin-bottom:20px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
          <h6 style="font-family:var(--font-head);font-weight:700;margin:0;color:var(--accent);">
            <i class="fa-solid fa-receipt me-2"></i>Chi tiết đơn hàng
          </h6>
          @if(TempData["OrderId"] != null){
            <span style="font-family:var(--font-head);font-weight:800;font-size:.9rem;background:rgba(0,255,255,.1);color:var(--accent);padding:4px 12px;border-radius:99px;">
              #TS@(TempData["OrderId"]?.ToString()?.PadLeft(4,'0'))
            </span>
          }
        </div>

        @{
          var payMethod = TempData["PaymentMethod"]?.ToString();
          var payLabel  = payMethod == "COD" ? "💵 Tiền mặt khi nhận hàng" : payMethod == "BankTransfer" ? "🏦 Chuyển khoản" : payMethod;
          var orderCount = TempData["OrderCount"]?.ToString();
        }

        @if(TempData["OrderName"] != null){
          <div style="display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);gap:12px;">
            <span style="color:var(--muted);font-size:.87rem;flex-shrink:0;">Người nhận</span>
            <span style="font-weight:600;font-size:.88rem;text-align:right;">@TempData["OrderName"]</span>
          </div>
        }
        @if(TempData["OrderPhone"] != null){
          <div style="display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);gap:12px;">
            <span style="color:var(--muted);font-size:.87rem;flex-shrink:0;">Số điện thoại</span>
            <span style="font-weight:600;font-size:.88rem;text-align:right;">@TempData["OrderPhone"]</span>
          </div>
        }
        @if(TempData["OrderAddress"] != null){
          <div style="display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);gap:12px;">
            <span style="color:var(--muted);font-size:.87rem;flex-shrink:0;">Địa chỉ</span>
            <span style="font-weight:600;font-size:.88rem;text-align:right;">@TempData["OrderAddress"]</span>
          </div>
        }
        @if(orderCount != null){
          <div style="display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);gap:12px;">
            <span style="color:var(--muted);font-size:.87rem;flex-shrink:0;">Số lượng SP</span>
            <span style="font-weight:600;font-size:.88rem;text-align:right;">@orderCount sản phẩm</span>
          </div>
        }
        @if(payLabel != null){
          <div style="display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);gap:12px;">
            <span style="color:var(--muted);font-size:.87rem;flex-shrink:0;">Thanh toán</span>
            <span style="font-weight:600;font-size:.88rem;text-align:right;">@payLabel</span>
          </div>
        }

        @if(TempData["OrderDiscount"] != null){
          <div style="display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);">
            <span style="color:var(--muted);font-size:.87rem;">Tạm tính</span>
            <span style="font-size:.88rem;text-decoration:line-through;color:var(--muted);">@TempData["OrderOriginal"]₫</span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);">
            <span style="color:var(--muted);font-size:.87rem;">Giảm giá voucher</span>
            <span style="font-size:.88rem;color:var(--success);font-weight:700;">-@TempData["OrderDiscount"]%</span>
          </div>
        }

        <div style="display:flex;justify-content:space-between;padding:14px 0 2px;">
          <span style="font-weight:700;font-size:1rem;">Tổng thanh toán</span>
          <span style="font-weight:800;font-size:1.15rem;color:var(--accent);font-family:var(--font-head);">@TempData["OrderTotal"]₫</span>
        </div>
      </div>

      <!-- Timeline giao hàng -->
      <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:18px 20px;margin-bottom:24px;text-align:left;">
        <h6 style="font-family:var(--font-head);font-weight:700;margin-bottom:14px;font-size:.88rem;color:var(--muted);">TIẾN TRÌNH ĐƠN HÀNG</h6>
        <div style="display:flex;align-items:flex-start;gap:14px;">
          @{ var stepDone = new bool[]{true,false,false,false}; }
          @{ var stepName = new string[]{"Đặt hàng","Xác nhận","Đang giao","Hoàn thành"}; }
          @{ var stepDesc = new string[]{"Đơn hàng đã được tiếp nhận","Xác nhận trong 2-4 giờ","Giao hàng 2-3 ngày","Nhận hàng & thanh toán COD"}; }
          @for(int si=0; si<stepName.Length; si++){
            <div style="flex:1;text-align:center;position:relative;">
              <div style="width:28px;height:28px;border-radius:50%;background:@(stepDone[si]?"linear-gradient(135deg,var(--success),#059669)":"var(--card2)");border:2px solid @(stepDone[si]?"var(--success)":"var(--border)");display:flex;align-items:center;justify-content:center;margin:0 auto 6px;font-size:.7rem;color:@(stepDone[si]?"white":"var(--muted)");">
                @if(stepDone[si]){<i class="fa-solid fa-check"></i>}else{<i class="fa-regular fa-clock"></i>}
              </div>
              <div style="font-size:.72rem;font-weight:700;color:@(stepDone[si]?"var(--success)":"var(--muted)");">@stepName[si]</div>
              <div style="font-size:.67rem;color:var(--muted);margin-top:2px;line-height:1.3;">@stepDesc[si]</div>
            </div>
          }
        </div>
      </div>
    }

    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="/Order/MyOrders" class="btn-primary-custom" style="padding:12px 28px;">
        <i class="fa-solid fa-list-check"></i> Xem đơn hàng
      </a>
      <a href="/Product" class="btn-secondary-custom" style="padding:12px 24px;">
        <i class="fa-solid fa-laptop"></i> Tiếp tục mua
      </a>
    </div>

  </div>
</div>
