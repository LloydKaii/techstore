@model TechStore.ViewModels.PagedViewModel<TechStore.Models.Product>

@{
    ViewData["Title"] = "Sản Phẩm";
}

<!-- PAGE HEADER -->
<div class="page-header">
    <div class="container">
        <h1>🛍️ Cửa Hàng Sản Phẩm</h1>
    </div>
</div>

<div class="container-fluid py-5">
    <div class="row g-5">
        
        <!-- LEFT: SIDEBAR FILTERS -->
        <div class="col-lg-3 mb-4">
            <div class="card-dark p-4" style="position: sticky; top: 120px; border-radius: var(--r);">
                
                <h5 class="section-title mb-4">🔍 Bộ Lọc</h5>
                
                <form method="get" id="filterForm">
                    
                    <!-- Category Filter -->
                    <div class="mb-4">
                        <h6 style="font-weight: 600; margin-bottom: 12px;">Danh Mục</h6>
                        @foreach(var cat in ViewBag.Categories ?? new List<TechStore.Models.Category>())
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="category" value="@cat.Name" 
                                       id="cat_@cat.Id" 
                                       @(Model.CategoryFilter == cat.Name ? "checked" : "")
                                       onchange="document.getElementById('filterForm').submit();" />
                                <label class="form-check-label" for="cat_@cat.Id" style="cursor: pointer;">
                                    @cat.Name
                                </label>
                            </div>
                        }
                    </div>
                    
                    <!-- Sort -->
                    <div class="mb-4">
                        <h6 style="font-weight: 600; margin-bottom: 12px;">Sắp Xếp</h6>
                        <select name="sortBy" class="form-control-dark w-100" onchange="document.getElementById('filterForm').submit();">
                            <option value="newest">Mới nhất</option>
                            <option value="price-asc">Giá: Thấp → Cao</option>
                            <option value="price-desc">Giá: Cao → Thấp</option>
                            <option value="rating">Đánh giá cao nhất</option>
                        </select>
                    </div>
                    
                    <button type="reset" class="btn-secondary-custom w-100">↻ Đặt lại</button>
                </form>
            </div>
        </div>
        
        <!-- RIGHT: PRODUCTS GRID -->
        <div class="col-lg-9">
            
            <!-- Header & Search -->
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
                <h4 style="margin: 0;">Sản Phẩm (@Model.TotalItems)</h4>
                <form method="get" style="display: flex; gap: 8px; flex-grow: 1; max-width: 400px;">
                    <input type="text" name="search" class="form-control-dark flex-grow-1" 
                           placeholder="Tìm kiếm sản phẩm..." value="@Model.Search" />
                    <button type="submit" class="btn-primary-custom" style="border: none; cursor: pointer;">
                        🔍
                    </button>
                </form>
            </div>
            
            <!-- Products Grid -->
            @if (Model.Items.Count() > 0)
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
                    @foreach(var product in Model.Items)
                    {
                        <div class="col" data-aos="fade-up">
                            @await Html.PartialAsync("_ProductCard", product)
                        </div>
                    }
                </div>
                
                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <nav style="margin-top: 40px; display: flex; justify-content: center;">
                        <ul class="pagination">
                            @if (Model.Page > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="?page=1@(Model.CategoryFilter != null ? $"&category={Model.CategoryFilter}" : "")">« Đầu</a>
                                </li>
                                <li class="page-item">
                                    <a class="page-link" href="?page=@(Model.Page - 1)@(Model.CategoryFilter != null ? $"&category={Model.CategoryFilter}" : "")">‹ Trước</a>
                                </li>
                            }
                            
                            @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                            {
                                @if (i == Model.Page)
                                {
                                    <li class="page-item active">
                                        <span class="page-link" style="background: var(--accent); border-color: var(--accent); color: #05080f;">@i</span>
                                    </li>
                                }
                                else
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="?page=@i@(Model.CategoryFilter != null ? $"&category={Model.CategoryFilter}" : "")">@i</a>
                                    </li>
                                }
                            }
                            
                            @if (Model.Page < Model.TotalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="?page=@(Model.Page + 1)@(Model.CategoryFilter != null ? $"&category={Model.CategoryFilter}" : "")">Sau ›</a>
                                </li>
                                <li class="page-item">
                                    <a class="page-link" href="?page=@Model.TotalPages@(Model.CategoryFilter != null ? $"&category={Model.CategoryFilter}" : "")">Cuối »</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div style="text-align: center; padding: 60px 20px;">
                    <i class="fa-solid fa-inbox" style="font-size: 3rem; color: var(--muted); opacity: 0.5; margin-bottom: 16px; display: block;"></i>
                    <p class="text-muted" style="font-size: 1.1rem;">Không tìm thấy sản phẩm nào</p>
                    <a href="/Product" class="btn-secondary-custom" style="display: inline-block; text-decoration: none; margin-top: 16px;">← Quay Lại</a>
                </div>
            }
        </div>
    </div>
</div>

<style>
.pagination .page-link {
    background: var(--card);
    border-color: var(--border);
    color: var(--muted);
    text-decoration: none;
    transition: all .2s;
}

.pagination .page-link:hover {
    background: var(--card2);
    color: var(--accent);
    border-color: var(--border-accent);
}

.pagination .page-item.active .page-link {
    background: var(--accent);
    border-color: var(--accent);
    color: #05080f;
}

@@media (max-width: 768px) {
    .col-lg-3 { margin-bottom: 2rem; }
}
</style>
