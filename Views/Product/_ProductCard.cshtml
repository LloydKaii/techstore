@model Product

<a href="/Product/Display/@Model.Id" style="text-decoration: none;">
    <div class="card-dark h-100" style="border-radius: var(--r); overflow: hidden; transition: all .3s; cursor: pointer; display: flex; flex-direction: column;">
        
        <!-- Image -->
        <div style="position: relative; overflow: hidden; height: 200px; background: var(--card2);">
            <img src="@(Model.ImageUrl ?? "https://images.unsplash.com/photo-1518709268805-4e9042af2176?w=400&q=80")" 
                 alt="@Model.Name" 
                 style="width: 100%; height: 100%; object-fit: cover; transition: transform .3s;" />
            
            <!-- Badge -->
            @if (!string.IsNullOrEmpty(Model.CategoryName))
            {
                <span style="position: absolute; top: 12px; right: 12px; background: var(--accent); color: #05080f; padding: 6px 12px; border-radius: 4px; font-size: .8rem; font-weight: 600;">
                    @Model.CategoryName
                </span>
            }
        </div>
        
        <!-- Content -->
        <div style="padding: 16px; display: flex; flex-direction: column; flex-grow: 1;">
            
            <!-- Name (truncated) -->
            <h5 style="margin: 0 0 8px 0; font-weight: 600; color: var(--text); font-size: .95rem; min-height: 2.3em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                @Model.Name
            </h5>
            
            <!-- Description (truncated) -->
            <p style="margin: 0 0 12px 0; font-size: .85rem; color: var(--muted); flex-grow: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                @(Model.Description ?? "Không có mô tả")
            </p>
            
            <!-- Price -->
            <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 12px; border-top: 1px solid var(--border);">
                <div class="text-accent" style="font-weight: 700; font-size: 1.1rem;">
                    @Model.Price.ToString("N0") đ
                </div>
                <button type="button" 
                        onclick="event.preventDefault(); addToCart(@Model.Id)" 
                        class="btn btn-sm" 
                        style="background: var(--accent); color: #05080f; border: none; border-radius: 4px; padding: 6px 12px; font-weight: 600; cursor: pointer; transition: all .2s;">
                    🛒
                </button>
            </div>
        </div>
    </div>
</a>

<script>
function addToCart(productId) {
    // GET /Cart/Add/{id} hoặc AJAX call
    window.location.href = '/Cart/Add/' + productId;
}
</script>
