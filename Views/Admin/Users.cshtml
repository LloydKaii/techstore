@model List<(TechStore.Models.ApplicationUser User, IList<string> Roles)>
@{ ViewData["Title"] = "Quản lý người dùng"; }

<div class="page-header animate-in">
  <div class="container">
    <div class="d-flex align-items-center gap-3 flex-wrap">
      <a href="/Admin/Dashboard" style="color:var(--muted);text-decoration:none;font-size:.88rem;display:flex;align-items:center;gap:5px;"><i class="fa-solid fa-arrow-left"></i>Dashboard</a>
    </div>
    <h1 style="margin-top:12px;"><i class="fa-solid fa-users me-2 text-accent"></i>Quản lý người dùng</h1>
    <p style="color:var(--muted);font-size:.88rem;margin-top:4px;">Cấp quyền và quản lý tài khoản</p>
  </div>
</div>

<div class="container py-5">
  <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;" class="animate-in">
    <table class="table-dark-custom">
      <thead>
        <tr>
          <th>Người dùng</th>
          <th>Email</th>
          <th>Quyền hiện tại</th>
          <th>Đổi quyền</th>
          <th style="text-align:right;">Xóa</th>
        </tr>
      </thead>
      <tbody>
        @foreach(var (user, roles) in Model){
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--accent2),var(--accent));display:flex;align-items:center;justify-content:center;font-size:.8rem;color:#05080f;font-weight:700;flex-shrink:0;">
                  @user.FullName.Substring(0,1).ToUpper()
                </div>
                <div>
                  <div style="font-weight:600;font-size:.9rem;">@user.FullName</div>
                  <div style="font-size:.75rem;color:var(--muted);">ID: @user.Id.Substring(0,8)...</div>
                </div>
              </div>
            </td>
            <td style="color:var(--muted);font-size:.88rem;">@user.Email</td>
            <td>
              @foreach(var r in roles){
                <span style="background:@(r=="Admin"?"rgba(0,255,255,.12)":r=="Manager"?"rgba(123,94,167,.12)":"rgba(52,211,153,.08)");color:@(r=="Admin"?"var(--accent)":r=="Manager"?"#c4aff0":"var(--success)");border:1px solid @(r=="Admin"?"rgba(0,255,255,.2)":r=="Manager"?"rgba(123,94,167,.2)":"rgba(52,211,153,.15)");padding:3px 10px;border-radius:99px;font-size:.72rem;font-weight:700;margin-right:4px;">
                  @r
                </span>
              }
              @if(!roles.Any()){<span style="color:var(--muted);font-size:.82rem;">—</span>}
            </td>
            <td>
              <form asp-action="SetRole" method="post" style="display:flex;gap:6px;align-items:center;">
                <input type="hidden" name="userId" value="@user.Id"/>
                <select name="role" class="form-control-dark" style="padding:6px 10px!important;font-size:.82rem!important;width:auto;">
                  @foreach(var r in (List<string>)ViewBag.AllRoles){
                    if(roles.Contains(r)){
                      <option value="@r" selected>@r</option>
                    } else {
                      <option value="@r">@r</option>
                    }
                  }
                </select>
                <button type="submit" class="btn-edit-custom" style="padding:6px 12px;font-size:.8rem;">
                  <i class="fa-solid fa-check"></i>Lưu
                </button>
              </form>
            </td>
            <td style="text-align:right;">
              @if(user.Email != User.Identity?.Name){
                <form asp-action="DeleteUser" method="post" onsubmit="return confirm('Xóa tài khoản @user.Email?')">
                  <input type="hidden" name="userId" value="@user.Id"/>
                  <button type="submit" class="btn-danger-custom" style="padding:6px 12px;font-size:.8rem;">
                    <i class="fa-solid fa-trash"></i>
                  </button>
                </form>
              } else {
                <span style="color:var(--muted);font-size:.75rem;">(Bạn)</span>
              }
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>
