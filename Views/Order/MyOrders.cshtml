@model List<TechStore.Models.Order>
@{ ViewData["Title"] = "Đơn hàng của tôi"; }
<div class="page-header animate-in" style="z-index:2;">
  <div class="container">
    <h1><i class="fa-solid fa-bag-shopping me-2 text-accent"></i>Đơn hàng của tôi</h1>
  </div>
</div>
<div class="container py-5" style="position:relative;z-index:2;">
  @if(!Model.Any()){
    <div style="text-align:center;padding:80px 20px;" class="animate-in">
      <div style="width:80px;height:80px;background:var(--card2);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:2rem;color:rgba(255,255,255,.08);"><i class="fa-solid fa-bag-shopping"></i></div>
      <h5 style="font-family:var(--font-head);">Chưa có đơn hàng nào</h5>
      <a href="/Product" class="btn-primary-custom mt-3"><i class="fa-solid fa-laptop"></i>Mua sắm ngay</a>
    </div>
  } else {
    <div class="d-flex flex-column gap-3 animate-in">
      @foreach(var o in Model){
        <div class="card-dark p-0" style="overflow:hidden;">
          <div style="padding:16px 20px;background:var(--card2);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;">
            <div>
              <span style="font-family:var(--font-head);font-weight:700;color:var(--accent);">#TS@o.Id.ToString("D4")</span>
              <span style="color:var(--muted);font-size:.82rem;margin-left:12px;">@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div style="display:flex;align-items:center;gap:10px;">
              <span style="background:@(o.Status=="Hoàn thành"?"rgba(52,211,153,.12)":o.Status=="Đã hủy"?"rgba(255,77,109,.1)":"rgba(251,191,36,.1)");color:@(o.Status=="Hoàn thành"?"var(--success)":o.Status=="Đã hủy"?"#ff7a8a":"var(--warning)");padding:4px 12px;border-radius:99px;font-size:.78rem;font-weight:700;">@o.Status</span>
              <a href="/Order/Detail/@o.Id" class="btn-view-custom" style="padding:5px 12px;font-size:.8rem;">Chi tiết</a>
            </div>
          </div>
          <div style="padding:16px 20px;display:flex;justify-content:space-between;align-items:center;">
            <div style="color:var(--muted);font-size:.88rem;">@o.Items.Count sản phẩm · @o.Address</div>
            <div style="font-family:var(--font-head);font-weight:800;color:var(--accent);font-size:1.05rem;">@o.Total.ToString("N0")₫</div>
          </div>
        </div>
      }
    </div>
  }
</div>
