@* Display.cshtml *@
@model TechStore.Models.Category
@{ ViewData["Title"] = Model.Name; }

<div class="page-header">
  <div class="container">
    <h1><i class="fa-solid fa-tag me-2 text-accent"></i>@Model.Name</h1>
  </div>
</div>
<div class="container py-5">
  <div class="row">
    <div class="col-lg-6">
      <div class="card-dark p-4 mb-4">
        <table style="width:100%;border-collapse:collapse;">
          <tr style="border-bottom:1px solid #1e2d45;">
            <td style="padding:12px 0;color:#8899aa;font-size:.88rem;width:40%;">Mã danh mục</td>
            <td style="padding:12px 0;color:#f0f4ff;font-weight:600;">#@Model.Id</td>
          </tr>
          <tr style="border-bottom:1px solid #1e2d45;">
            <td style="padding:12px 0;color:#8899aa;font-size:.88rem;">Tên danh mục</td>
            <td style="padding:12px 0;color:#f0f4ff;font-weight:600;">@Model.Name</td>
          </tr>
          <tr>
            <td style="padding:12px 0;color:#8899aa;font-size:.88rem;">Mô tả</td>
            <td style="padding:12px 0;color:#f0f4ff;">@(Model.Description ?? "—")</td>
          </tr>
        </table>
      </div>
      @if (Model.Products?.Any() == true)
      {
        <h5 style="font-family:'Sora',sans-serif;color:#f0f4ff;margin-bottom:12px;">Sản phẩm trong danh mục (@Model.Products.Count)</h5>
        <div class="card-dark" style="overflow:hidden;">
          @foreach (var p in Model.Products)
          {
            <div style="display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid #1e2d45;">
              @if (!string.IsNullOrEmpty(p.ImageUrl))
              {
                <img src="@p.ImageUrl" style="width:44px;height:44px;border-radius:6px;object-fit:cover;" alt="@p.Name"/>
              }
              <span style="color:#f0f4ff;font-size:.9rem;flex:1;">@p.Name</span>
              <span style="color:var(--accent);font-weight:700;font-size:.88rem;">@p.Price.ToString("N0")₫</span>
            </div>
          }
        </div>
      }
      <div class="d-flex gap-3 mt-4">
        <a href="/Category/Update/@Model.Id" class="btn-primary-custom px-4"><i class="fa-solid fa-pen me-2"></i>Chỉnh sửa</a>
        <a href="/Category" class="btn-secondary-custom px-4"><i class="fa-solid fa-arrow-left me-2"></i>Quay lại</a>
      </div>
    </div>
  </div>
</div>
