@model IEnumerable<TechStore.Models.Category>

@{
    ViewData["Title"] = "Danh Mục";
    var isAdmin = User.IsInRole("Admin") || User.IsInRole("Manager");
}

<!-- PAGE HEADER -->
<div class="page-header">
    <div class="container">
        <h1>📂 Danh Mục Sản Phẩm</h1>
        <p class="text-muted">Khám phá các loại linh kiện PC của chúng tôi</p>
    </div>
</div>

<div class="container py-5">
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @{
            string[] categoryIcons = new string[]
            {
                "🖥️", "⚡", "🎮", "🧠", "💾", "🔌", "⚡", "📦"
            };
            int iconIndex = 0;
        }

        @foreach(var category in Model)
        {
            <div class="col" data-aos="fade-up">
                <a href="/Category/Display/@category.Id" style="text-decoration: none;">
                    <div class="card-dark p-5 text-center" style="height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; border-radius: var(--r); overflow: hidden; position: relative; transition: all .3s; cursor: pointer;">
                        
                        <!-- Background gradient -->
                        <div style="position: absolute; inset: 0; background: linear-gradient(135deg, rgba(0,255,255,.05) 0%, rgba(123,94,167,.05) 100%); opacity: 0; transition: opacity .3s;"></div>
                        
                        <!-- Content -->
                        <div style="position: relative; z-index: 1;">
                            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, rgba(0,255,255,.1), rgba(123,94,167,.1)); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-size: 2rem;">
                                @{
                                    string GetIcon(string catName) => catName switch
                                    {
                                        "CPU" => "⚡",
                                        "GPU" => "🎮",
                                        "RAM" => "🧠",
                                        "Storage" => "💾",
                                        "Motherboard" => "🔌",
                                        "PSU" => "⚡",
                                        "Case" => "📦",
                                        "Linh kiện" => "🔧",
                                        _ => "🖥️"
                                    };
                                }
                                @Html.Raw(GetIcon(category.Name))
                            </div>
                            
                            <h3 style="margin: 0 0 8px 0; color: var(--text); font-weight: 700;">
                                @category.Name
                            </h3>
                            
                            <p class="text-muted" style="margin: 0; font-size: .95rem;">
                                @((category.Products?.Count() ?? 0) + " sản phẩm")
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div style="text-align: center; padding: 60px 20px;">
            <i class="fa-solid fa-inbox" style="font-size: 3rem; color: var(--muted); opacity: 0.5; margin-bottom: 16px; display: block;"></i>
            <p class="text-muted" style="font-size: 1.1rem;">Không tìm thấy danh mục nào</p>
        </div>
    }
</div>

