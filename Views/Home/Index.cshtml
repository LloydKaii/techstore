@model TechStore.ViewModels.PagedViewModel<TechStore.Models.Product>
@{ ViewData["Title"] = "Trang chủ"; }

<style>
.hero{position:relative;min-height:580px;display:flex;align-items:center;overflow:hidden;background:linear-gradient(135deg,rgba(5,8,15,.98) 0%,rgba(10,15,30,.98) 100%);border-bottom:1px solid var(--border);z-index:2;}
.hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(0,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,255,.025) 1px,transparent 1px);background-size:50px 50px;animation:gridMove 30s linear infinite;pointer-events:none;}
@@keyframes gridMove{to{background-position:50px 50px;}}
.hero-glow{position:absolute;width:600px;height:600px;background:radial-gradient(circle,rgba(0,255,255,.08) 0%,transparent 65%);top:50%;left:55%;transform:translate(-50%,-50%);pointer-events:none;animation:orbDrift 10s ease-in-out infinite;}
.hero-content{position:relative;z-index:2;padding:90px 0;}
.hero-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(0,255,255,.08);color:var(--accent);border:1px solid rgba(0,255,255,.18);padding:6px 16px;border-radius:99px;font-size:.78rem;font-weight:700;margin-bottom:22px;letter-spacing:.3px;animation:glowPulse 2s ease-in-out infinite;}
.hero-title{font-family:var(--font-head);font-size:clamp(2.2rem,4.5vw,3.6rem);font-weight:800;line-height:1.12;letter-spacing:-.6px;margin-bottom:18px;}
.hero-title .hl{background:linear-gradient(135deg,var(--accent) 0%,var(--accent2) 50%,var(--accent3) 100%);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:shimmerText 3s linear infinite;}
.hero-sub{color:var(--muted);font-size:1rem;line-height:1.75;max-width:460px;margin-bottom:34px;}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;}
.hero-img-wrap{position:relative;display:flex;align-items:center;justify-content:center;}
.hero-img-wrap::before{content:'';position:absolute;width:380px;height:380px;background:radial-gradient(circle,rgba(0,255,255,.1) 0%,transparent 65%);border-radius:50%;animation:glowPulse 4s ease-in-out infinite;}
.hero-img{max-width:480px;width:100%;border-radius:22px;border:1px solid rgba(0,255,255,.12);box-shadow:0 30px 90px rgba(0,0,0,.6),0 0 0 1px rgba(0,255,255,.06);position:relative;z-index:1;transition:transform .5s ease;}
.hero-img:hover{transform:translateY(-8px) scale(1.01);}
.hero-stats{display:flex;gap:28px;margin-top:36px;flex-wrap:wrap;}
.hstat{text-align:center;}
.hstat-val{font-family:var(--font-head);font-size:1.4rem;font-weight:800;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hstat-lbl{font-size:.75rem;color:var(--muted);margin-top:2px;}

/* Product cards */
.prod-card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;height:100%;display:flex;flex-direction:column;transition:all .35s ease;position:relative;}
.prod-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,255,255,.04),transparent);opacity:0;transition:opacity .3s;pointer-events:none;z-index:0;}
.prod-card:hover{transform:translateY(-10px);border-color:rgba(0,255,255,.25);box-shadow:0 24px 70px rgba(0,0,0,.5),0 0 0 1px rgba(0,255,255,.08),0 0 40px rgba(0,255,255,.04);}
.prod-card:hover::before{opacity:1;}
.prod-img-wrap{position:relative;overflow:hidden;background:var(--card2);}
.prod-img{width:100%;height:215px;object-fit:cover;transition:transform .5s ease;display:block;}
.prod-card:hover .prod-img{transform:scale(1.07);}
.prod-noimg{width:100%;height:215px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--card2),var(--bg2));font-size:3rem;color:rgba(255,255,255,.06);}
.prod-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(5,8,15,.9) 0%,transparent 55%);opacity:0;transition:opacity .3s;display:flex;align-items:flex-end;justify-content:center;padding-bottom:16px;gap:8px;z-index:1;}
.prod-card:hover .prod-overlay{opacity:1;}
.prod-body{padding:18px;display:flex;flex-direction:column;flex:1;position:relative;z-index:1;}
.prod-name{font-family:var(--font-head);font-weight:700;font-size:.95rem;color:var(--text);margin-bottom:7px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
.prod-desc{font-size:.82rem;color:var(--muted);line-height:1.55;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:14px;flex:1;}
.prod-price{font-family:var(--font-head);font-size:1.18rem;font-weight:800;background:linear-gradient(135deg,var(--accent),#00b8d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:14px;}
.prod-actions{display:flex;gap:8px;}

/* Stats bar */
.stats-bar{background:rgba(10,15,30,.9);border-bottom:1px solid var(--border);padding:18px 0;position:relative;z-index:2;backdrop-filter:blur(10px);}
.stats-inner{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;}
.stat-item{display:flex;align-items:center;gap:11px;padding:8px 32px;border-right:1px solid var(--border);}
.stat-item:last-child{border-right:none;}
.stat-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;}
.stat-val{font-family:var(--font-head);font-weight:700;font-size:1.05rem;}
.stat-lbl{font-size:.74rem;color:var(--muted);}
</style>

<!-- HERO -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow"></div>
  <div class="container hero-content">
    <div class="row align-items-center g-5">
      <div class="col-lg-6 animate-in">
        <div class="hero-badge"><i class="fa-solid fa-bolt"></i>Flash Sale — Giảm đến 30%</div>
        <h1 class="hero-title">
          Công nghệ<br/>
          <span class="hl">đỉnh cao,</span><br/>
          giá tốt nhất
        </h1>
        <p class="hero-sub">Hàng ngàn laptop, PC và phụ kiện chính hãng. Giao hàng toàn quốc trong 24h. Bảo hành 12 tháng.</p>
        <div class="hero-btns">
          <a href="#products" class="btn-primary-custom" style="padding:14px 32px;font-size:.95rem;">
            <i class="fa-solid fa-arrow-down"></i>Khám phá ngay
          </a>
          @if(User.IsInRole("Admin")||User.IsInRole("Manager")){
            <a href="/Product/Add" class="btn-secondary-custom" style="padding:14px 24px;font-size:.95rem;">
              <i class="fa-solid fa-plus"></i>Thêm sản phẩm
            </a>
          }
        </div>
        <div class="hero-stats">
          <div class="hstat"><div class="hstat-val">@Model.TotalItems+</div><div class="hstat-lbl">Sản phẩm</div></div>
          <div class="hstat"><div class="hstat-val">24h</div><div class="hstat-lbl">Giao hàng</div></div>
          <div class="hstat"><div class="hstat-val">12T</div><div class="hstat-lbl">Bảo hành</div></div>
          <div class="hstat"><div class="hstat-val">99%</div><div class="hstat-lbl">Hài lòng</div></div>
        </div>
      </div>
      <div class="col-lg-6 animate-in-delay">
        <div class="hero-img-wrap">
          <img src="https://images.unsplash.com/photo-1593642702821-c8da6771f0c6?w=600&q=85" class="hero-img" alt="Hero"/>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar animate-in-delay2">
  <div class="container">
    <div class="stats-inner">
      <div class="stat-item">
        <div class="stat-icon" style="background:rgba(0,255,255,.08);color:var(--accent);"><i class="fa-solid fa-truck-fast"></i></div>
        <div><div class="stat-val">Miễn phí</div><div class="stat-lbl">Giao hàng</div></div>
      </div>
      <div class="stat-item">
        <div class="stat-icon" style="background:rgba(123,94,167,.1);color:#c4aff0;"><i class="fa-solid fa-shield-halved"></i></div>
        <div><div class="stat-val">12 tháng</div><div class="stat-lbl">Bảo hành</div></div>
      </div>
      <div class="stat-item">
        <div class="stat-icon" style="background:rgba(52,211,153,.08);color:var(--success);"><i class="fa-solid fa-rotate-left"></i></div>
        <div><div class="stat-val">30 ngày</div><div class="stat-lbl">Đổi trả</div></div>
      </div>
      <div class="stat-item">
        <div class="stat-icon" style="background:rgba(251,191,36,.08);color:var(--warning);"><i class="fa-solid fa-headset"></i></div>
        <div><div class="stat-val">24/7</div><div class="stat-lbl">Hỗ trợ</div></div>
      </div>
    </div>
  </div>
</div>

<!-- PRODUCTS -->
<section class="py-5" id="products" style="position:relative;z-index:2;">
  <div class="container">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
      <h2 class="section-title">Sản phẩm nổi bật</h2>
      <a href="/Product" class="btn-secondary-custom" style="padding:9px 20px;font-size:.85rem;">
        Xem tất cả <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>

    @if(Model.Items.Any()){
      <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach(var item in Model.Items){
          <div class="col">
            <div class="prod-card">
              <div class="prod-img-wrap">
                @if(!string.IsNullOrEmpty(item.ImageUrl)){
                  <img src="@item.ImageUrl" alt="@item.Name" class="prod-img"/>
                } else {
                  <div class="prod-noimg"><i class="fa-solid fa-image"></i></div>
                }
                <!-- Overlay: chỉ hiện nút Sửa cho Admin/Manager -->
                <div class="prod-overlay">
                  <a href="/Product/Display/@item.Id" class="btn-view-custom" style="font-size:.8rem;"><i class="fa-solid fa-eye"></i>Xem</a>
                  @if(User.IsInRole("Admin")||User.IsInRole("Manager")){
                    <a href="/Product/Update/@item.Id" class="btn-edit-custom" style="font-size:.8rem;"><i class="fa-solid fa-pen"></i>Sửa</a>
                  }
                </div>
                @if(item.Category!=null){
                  <span class="badge-cat" style="position:absolute;top:12px;left:12px;z-index:2;">@item.Category.Name</span>
                }
              </div>
              <div class="prod-body">
                <h5 class="prod-name">@item.Name</h5>
                @if(!string.IsNullOrEmpty(item.Description)){
                  <p class="prod-desc">@item.Description</p>
                }
                <div class="prod-price">@item.Price.ToString("N0")₫</div>
                <div class="prod-actions">
                  <a href="/Product/Display/@item.Id" class="btn-view-custom" style="flex:1;justify-content:center;"><i class="fa-solid fa-eye"></i>Chi tiết</a>
                  @if(User.IsInRole("Admin")||User.IsInRole("Manager")){
                    <a href="/Product/Update/@item.Id" class="btn-edit-custom" style="flex:1;justify-content:center;"><i class="fa-solid fa-pen"></i>Sửa</a>
                  }
                </div>
              </div>
            </div>
          </div>
        }
      </div>
    } else {
      <div style="text-align:center;padding:80px 20px;">
        <div style="width:80px;height:80px;background:var(--card2);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:2rem;color:rgba(255,255,255,.08);"><i class="fa-solid fa-box-open"></i></div>
        <h5 style="font-family:var(--font-head);margin-bottom:8px;">Chưa có sản phẩm</h5>
        @if(User.IsInRole("Admin")||User.IsInRole("Manager")){
          <a href="/Product/Add" class="btn-primary-custom mt-2"><i class="fa-solid fa-plus"></i>Thêm sản phẩm</a>
        }
      </div>
    }
  </div>
</section>
